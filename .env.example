# SEOgenious Environment Configuration

# Session Secret (REQUIRED)
# Generate a random string for production
SESSION_SECRET=change-this-to-a-random-secret-key-in-production

# n8n Webhook Integration (OPTIONAL)
# Uncomment and configure to enable workflow automation

# n8n Webhook Base URL
# For n8n Cloud: https://yourname.app.n8n.cloud/webhook
# For Self-Hosted: http://localhost:5678/webhook
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# n8n Basic Authentication (Optional, but recommended)
# Only needed if you enabled Basic Auth in n8n webhook settings
# N8N_AUTH_USER=your-username
# N8N_AUTH_PASS=your-password

# Database Configuration (Future)
# Uncomment when migrating from in-memory to PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/seogenious

# AI Configuration
# ================

# Enable Real AI (default: false)
# When false, uses mock AI responses. When true, uses real OpenAI API.
ENABLE_REAL_AI=false

# AI Mode (default: mock)
# Options: "mock" (free, uses mock data) or "real" (uses OpenAI API, costs money)
AI_MODE=mock

# OpenAI API Key (OPTIONAL - only needed if ENABLE_REAL_AI=true and not using Replit AI Integration)
# Get your key from https://platform.openai.com/api-keys
# Note: Replit AI Integration provides OpenAI access without your own API key (billed to Replit credits)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Replit AI Integration (Automatically configured if using Replit)
# These are set automatically by Replit - DO NOT manually set these
# AI_INTEGRATIONS_OPENAI_BASE_URL=auto
# AI_INTEGRATIONS_OPENAI_API_KEY=auto

# Environment
NODE_ENV=development
