# SEOgenious Environment Configuration

# Session Secret (REQUIRED)
# Generate a random string for production
SESSION_SECRET=change-this-to-a-random-secret-key-in-production

# n8n Webhook Integration (OPTIONAL)
# Uncomment and configure to enable workflow automation

# n8n Webhook Base URL
# For n8n Cloud: https://yourname.app.n8n.cloud/webhook
# For Self-Hosted: http://localhost:5678/webhook
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# n8n Basic Authentication (Optional, but recommended)
# Only needed if you enabled Basic Auth in n8n webhook settings
# N8N_AUTH_USER=your-username
# N8N_AUTH_PASS=your-password

# Database Configuration (Future)
# Uncomment when migrating from in-memory to PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/seogenious

# OpenAI API Key (Future - for real AI features)
# OPENAI_API_KEY=sk-your-openai-api-key

# Environment
NODE_ENV=development
